{
  "routes": [
    { "src": "/api/admin-login", "dest": "/api/admin-login.js" },
    { "src": "/api/admin-auth-check", "dest": "/api/admin-auth-check.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin-login.html", "dest": "/admin-login.html" },
    { "src": "/admin-check", "dest": "/api/admin-auth-check.js", "status": 302 },
    { "src": "/admin/config.yml", "dest": "/admin/config.yml" },
    { "src": "/admin/index.html", "dest": "/admin/index.html" },
    { "src": "/admin", "dest": "/api/admin-auth-check.js", "status": 302 },
    { "src": "/admin/", "dest": "/api/admin-auth-check.js", "status": 302 },
    { "src": "/admin/(.*)", "dest": "/admin/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Cache-Control",           "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.jsdelivr.net https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://unpkg.com https://cdn.jsdelivr.net https://api.github.com https://challenges.cloudflare.com https://github.com https://www.githubstatus.com; frame-src https://github.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self';" }
      ]
    },
    {
      "source": "/_data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}